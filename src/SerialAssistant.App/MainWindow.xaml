<Window x:Class="SerialAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Serial Assistant" Height="600" Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Serial Port Settings Area -->
        <GroupBox Grid.Row="0" Header="串口设置" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="串口:" VerticalAlignment="Center" Margin="5" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding SerialSettings.AvailablePorts}"
                          SelectedItem="{Binding SerialSettings.SelectedPortName}"
                          IsEnabled="{Binding SerialSettings.IsSettingsEnabled}"
                          Width="120" Margin="5" />

                <Button Grid.Row="0" Grid.Column="2"
                        Content="刷新"
                        Command="{Binding RefreshPortsCommand}"
                        Width="80" Margin="5" />

                <TextBlock Grid.Row="0" Grid.Column="3" Text="波特率:" VerticalAlignment="Center" Margin="15,5,5,5" />
                <ComboBox Grid.Row="0" Grid.Column="4"
                          ItemsSource="{Binding SerialSettings.BaudRates}"
                          SelectedItem="{Binding SerialSettings.SelectedBaudRate}"
                          IsEnabled="{Binding SerialSettings.IsSettingsEnabled}"
                          Width="100" Margin="5" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="数据位:" VerticalAlignment="Center" Margin="5" />
                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding SerialSettings.DataBitsOptions}"
                          SelectedItem="{Binding SerialSettings.SelectedDataBits}"
                          IsEnabled="{Binding SerialSettings.IsSettingsEnabled}"
                          Width="120" Margin="5" />

                <TextBlock Grid.Row="1" Grid.Column="2" Text="校验位:" VerticalAlignment="Center" Margin="15,5,5,5" />
                <ComboBox Grid.Row="1" Grid.Column="3"
                          ItemsSource="{Binding SerialSettings.ParityOptions}"
                          SelectedItem="{Binding SerialSettings.SelectedParity}"
                          IsEnabled="{Binding SerialSettings.IsSettingsEnabled}"
                          Width="100" Margin="5" />

                <TextBlock Grid.Row="1" Grid.Column="4" Text="停止位:" VerticalAlignment="Center" Margin="15,5,5,5" />
                <ComboBox Grid.Row="1" Grid.Column="5"
                          ItemsSource="{Binding SerialSettings.StopBitsOptions}"
                          SelectedItem="{Binding SerialSettings.SelectedStopBits}"
                          IsEnabled="{Binding SerialSettings.IsSettingsEnabled}"
                          Width="100" Margin="5" />

                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="7"
                        Content="打开/关闭"
                        Command="{Binding ToggleConnectionCommand}"
                        Width="100" Margin="5" VerticalAlignment="Center" />
            </Grid>
        </GroupBox>

        <!-- Receive Area -->
        <GroupBox Grid.Row="1" Header="接收区" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                    <CheckBox Content="HEX 显示"
                              IsChecked="{Binding IsHexDisplay}"
                              VerticalAlignment="Center"
                              Margin="0,0,20,0" />
                    <TextBlock Text="接收计数:" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="{Binding ReceiveDisplay.ReceivedBytesCount}" VerticalAlignment="Center" FontWeight="Bold" />
                    <Button Content="清空接收区"
                            Command="{Binding ClearReceiveCommand}"
                            Margin="20,0,0,0"
                            Padding="10,3" />
                </StackPanel>

                <TextBox Grid.Row="1"
                         Text="{Binding ReceiveDisplay.ReceivedText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         Margin="5" />
            </Grid>
        </GroupBox>

        <!-- Send Area -->
        <GroupBox Grid.Row="2" Header="发送区" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                    <TextBlock Text="发送模式:" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <ComboBox ItemsSource="{Binding SendModes}"
                              SelectedItem="{Binding SelectedSendMode}"
                              Width="100" Margin="0,0,20,0" />
                    <TextBlock Text="发送计数:" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="{Binding SentBytesCount}" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>

                <TextBox Grid.Row="1"
                         Text="{Binding SendText, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="5" />

                <Button Grid.Row="2"
                        Content="发送"
                        Command="{Binding SendCommand}"
                        HorizontalAlignment="Right"
                        Width="100"
                        Margin="5" />
            </Grid>
        </GroupBox>

        <!-- Status Area -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="状态: " FontWeight="Bold" />
                    <TextBlock Text="{Binding ConnectionState}" Margin="0,0,20,0" />
                    <TextBlock Text="{Binding StatusMessage}" />
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
