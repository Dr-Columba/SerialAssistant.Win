<Window x:Class="SerialAssistant.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SerialAssistant.App.Views"
        Title="SerialAssistant.Win - Engineering Communication Tool" Height="700" Width="1100">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Status Bar -->
        <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <Grid Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="SerialAssistant.Win" FontWeight="Bold" FontSize="14" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="状态: " VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Terminal.ConnectionState}" VerticalAlignment="Center" FontWeight="Bold" Margin="5,0,20,0" />
                    <TextBlock Text="{Binding Terminal.SerialSettings.SelectedPortName}" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="@" VerticalAlignment="Center" Margin="0,0,5,0" />
                    <TextBlock Text="{Binding Terminal.SerialSettings.SelectedBaudRate}" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="2" Text="v0.3.3" VerticalAlignment="Center" Foreground="Gray" />
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Navigation Panel -->
            <Border Grid.Column="0" Background="#F8F8F8" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="导航" FontWeight="Bold" Margin="10,10,10,5" />

                    <StackPanel Grid.Row="1" Margin="5">
                        <Button Content="Terminal" Margin="5" Padding="10,8" HorizontalContentAlignment="Left"
                                Background="LightBlue" FontWeight="Bold" />
                        <Button Content="Modbus" Margin="5" Padding="10,8" HorizontalContentAlignment="Left"
                                IsEnabled="False" />
                        <Button Content="Templates" Margin="5" Padding="10,8" HorizontalContentAlignment="Left"
                                IsEnabled="False" />
                        <Button Content="Logs" Margin="5" Padding="10,8" HorizontalContentAlignment="Left"
                                IsEnabled="False" />
                        <Button Content="Settings" Margin="5" Padding="10,8" HorizontalContentAlignment="Left"
                                IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Workspace - Terminal Page -->
            <views:TerminalPage Grid.Column="1" DataContext="{Binding Terminal}" />
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="#F0F0F0" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <Grid Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Ready" VerticalAlignment="Center" />

                <TextBlock Grid.Column="1" Text="Feature F2B2: MainWindowViewModel Terminal Cleanup" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" />

                <TextBlock Grid.Column="2" Text="Engineering Communication Tool" VerticalAlignment="Center" Foreground="Gray" />
            </Grid>
        </Border>
    </Grid>
</Window>
