<UserControl x:Class="SerialAssistant.App.Views.ModbusPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Modbus" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="参数设置" Margin="0,0,4,0">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="传输模式:" VerticalAlignment="Center" Margin="4,2" />
                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding TransportModes}"
                              SelectedItem="{Binding SelectedTransportMode}" Margin="4,2" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="请求类型:" VerticalAlignment="Center" Margin="4,2" />
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding RequestKinds}"
                              SelectedItem="{Binding SelectedRequestKind}" Margin="4,2" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="UnitId:" VerticalAlignment="Center" Margin="4,2" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding UnitId, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="TransactionId:" VerticalAlignment="Center" Margin="4,2" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding TransactionId, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="起始地址:" VerticalAlignment="Center" Margin="4,2" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding StartAddress, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="数量:" VerticalAlignment="Center" Margin="4,2" />
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="单寄存器值:" VerticalAlignment="Center" Margin="4,2" />
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SingleWriteValue, UpdateSourceTrigger=PropertyChanged}" Margin="4,2" />
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="多寄存器值 (HEX)" Margin="4,0,0,0">
                <TextBox Text="{Binding MultipleWriteValuesText, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="4" Height="140" />
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Build Request" Command="{Binding BuildRequestCommand}" Padding="10,4" Margin="0,0,4,0" />
            <Button Content="Parse Response" Command="{Binding ParseResponseCommand}" Padding="10,4" Margin="0,0,4,0" />
            <Button Content="Clear" Command="{Binding ClearCommand}" Padding="10,4" />
        </StackPanel>

        <GroupBox Grid.Row="3" Header="请求 (HEX)" Margin="0,0,0,8">
            <TextBox Text="{Binding RequestHex, Mode=OneWay}" IsReadOnly="True"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="4" />
        </GroupBox>

        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="响应 (HEX, 输入)" Margin="0,0,4,0">
                <TextBox Text="{Binding ResponseHex, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="4" />
            </GroupBox>

            <GroupBox Grid.Column="1" Header="解析结果" Margin="4,0,0,0">
                <TextBox Text="{Binding ParsedSummary, Mode=OneWay}" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="4" />
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,4,0,0">
            <TextBlock Text="状态: " FontWeight="Bold" />
            <TextBlock Text="{Binding StatusMessage}" />
        </StackPanel>
    </Grid>
</UserControl>